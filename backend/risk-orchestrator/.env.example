# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PRD-1 AI Engine ──────────────────────────────────
# Leave empty to use mock responses
PRD1_BASE_URL=

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ── Cache ────────────────────────────────────────────
CACHE_TTL_MS=300000

# ── CORS ─────────────────────────────────────────────
CORS_ORIGIN=*
