# ============================================
# Project Vanguard — Monorepo .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
.next/
out/
build/
dist/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Python (AI services)
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
*.egg-info/

# Flutter (mobile app)
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/

# Docker
*.log

# Misc
*.pem
.vercel
next-env.d.ts
coverage/

# GSD planning (local only)
.agent/
.planning/
*.pkl
