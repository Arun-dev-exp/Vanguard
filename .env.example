# ============================================
# Project Vanguard — Environment Variables
# ============================================
# Copy this file to .env in the relevant service directory
# and fill in the required values.

# --- Frontend ---
# NEXT_PUBLIC_API_URL=http://localhost:8000/api
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# --- Backend ---
# DATABASE_URL=postgresql://user:password@localhost:5432/vanguard
# JWT_SECRET=your-secret-key
# REDIS_URL=redis://localhost:6379

# --- AI Services ---
# OPENAI_API_KEY=sk-...
# MODEL_ENDPOINT=http://localhost:5000
# GEMINI_API_KEY=

# --- General ---
# NODE_ENV=development
# LOG_LEVEL=debug

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
API_BASE_URL=http://localhost:8000
DEMO_MODE=true

# --- Social Media Scanners ---
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=python:vanguard:v1.0 (by /u/your_username)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# --- ScamGuard Node App ---
PRD1_BASE_URL=http://localhost:8000
PRD2_BASE_URL=http://localhost:3002
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-key
DEEPGRAM_API_KEY=your-deepgram-api-key