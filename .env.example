# ══════════════════════════════════════════════════════════════
# Project Vanguard — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Supabase (Shared Database) ───────────────────────────────
SUPABASE_URL=https://ecrtsqbpgjupiqoasoqr.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── PRD-1: AI Fraud Intelligence Engine ──────────────────────
PRD1_PORT=8000
PRD1_BASE_URL=http://localhost:8000
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── PRD-2: Risk Orchestrator ────────────────────────────────
PRD2_PORT=4000
PRD2_BASE_URL=http://localhost:4000
PRD2_WS_URL=ws://localhost:4000/ws/alerts

# ── PRD-4: ScamGuard ────────────────────────────────────────
SCAMGUARD_PORT=3001
SCAMGUARD_PUBLIC_URL=http://localhost:3001

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Twilio (Audio Stream)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# ── General ─────────────────────────────────────────────────
NODE_ENV=development
